# --- Slack (Socket Mode by default) ---
# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token with connections:write scope (xapp-...)
SLACK_APP_TOKEN=xapp-...
# User token (xoxp-...). Required for the Real-Time Search API
# (assistant.search.context). User-token scopes to request:
#   search:read.public   (public channels)
#   search:read.private  (private channels, optional)
#   search:read.im       (DMs, optional)
#   search:read.mpim     (multi-party DMs, optional)
# The legacy `search:read` scope alone is NOT enough — RTS uses the newer
# per-channel-type scopes. Reinstall the Slack app after adding them.
SLACK_USER_TOKEN=xoxp-...

# --- LLM (pick one as ACTIVE_LLM: gemini | openai | claude | qwen) ---
ACTIVE_LLM=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic / Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Qwen (Alibaba DashScope, OpenAI-compatible mode — reuses the OpenAI client)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
# Base URL for DashScope compatible-mode. Default is the international endpoint;
# use https://dashscope.aliyuncs.com/compatible-mode/v1 for the Beijing region.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- App ---
PORT=3000
UI_BASE_URL=http://localhost:5173

# --- Database (Prisma) ---
# Local dev uses SQLite. For production, switch the datasource provider in
# prisma/schema.prisma to "postgresql" and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"
