# --- Slack (Socket Mode by default) ---
# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token with connections:write scope (xapp-...)
SLACK_APP_TOKEN=xapp-...
# User token (xoxp-...). Which scopes to request depends on the branch:
#   main       — search.messages           → search:read
#   rts-api    — assistant.search.context  → search:read.public
#                                            (+ search:read.private / .im / .mpim
#                                            as needed)
# `main` uses classic search.messages so the app works in Slack Developer
# Program sandboxes (which don't enable the RTS API tier).
# Reinstall the Slack app after changing scopes.
SLACK_USER_TOKEN=xoxp-...

# --- LLM (pick one as ACTIVE_LLM: gemini | openai | claude | qwen) ---
ACTIVE_LLM=gemini

# Gemini (free tier: gemini-2.5-flash is the sweet spot for extraction)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic / Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Qwen (Alibaba DashScope, OpenAI-compatible mode — reuses the OpenAI client)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
# Base URL for DashScope compatible-mode. Default is the international endpoint;
# use https://dashscope.aliyuncs.com/compatible-mode/v1 for the Beijing region.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- App ---
PORT=3000
UI_BASE_URL=http://localhost:5173

# Persistence: not currently active. Graphs and user prefs live in an
# in-memory Map (see server/src/store.ts and server/src/db.ts) — restart
# = clean slate. When the PERSISTENCE=prisma toggle lands, DATABASE_URL
# will come back here.
