# --- Slack (Socket Mode by default) ---
# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token with connections:write scope (xapp-...)
SLACK_APP_TOKEN=xapp-...
# User token with search:read scope (xoxp-...). Required for search.messages.
SLACK_USER_TOKEN=xoxp-...

# --- LLM (pick one as ACTIVE_LLM: gemini | openai | claude | qwen) ---
ACTIVE_LLM=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic / Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Qwen (Alibaba DashScope, OpenAI-compatible mode — reuses the OpenAI client)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
# Base URL for DashScope compatible-mode. Default is the international endpoint;
# use https://dashscope.aliyuncs.com/compatible-mode/v1 for the Beijing region.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- App ---
PORT=3000
UI_BASE_URL=http://localhost:5173

# Set to true to bypass the FREE-tier "5 maps/month" quota (handy in development).
# Leave unset/false in production to enforce billing limits.
DISABLE_BILLING_LIMIT=false

# --- Database (Prisma) ---
# Local dev uses SQLite. For production, switch the datasource provider in
# prisma/schema.prisma to "postgresql" and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"

# --- Secrets encryption (BYOK keys at rest) ---
# Long, random, and STABLE — rotating this invalidates all stored BYOK keys.
# Required in production; a dev fallback is used if unset (insecure).
ENCRYPTION_KEY=change-me-to-a-long-random-string
